@@ -10,6 +10,13 @@ test_description='git repack works correctly'
 GIT_TEST_MULTI_PACK_INDEX=0
 GIT_TEST_MULTI_PACK_INDEX_WRITE_INCREMENTAL=0

+# bit pack-objects accepts --filter as a no-op,
+# so repack tests that depend on --filter semantics are skipped under shim.
+shim_cmds="${SHIM_CMDS:-${GIT_SHIM_CMDS:-}}"
+case " $shim_cmds " in
+*" pack-objects "*) test_set_prereq BIT_PACK_OBJECTS ;;
+esac
+
 commit_and_pack () {
 	test_commit "$@" 1>&2 &&
 	incrpackid=$(git pack-objects --all --unpacked --incremental .git/objects/pack/pack </dev/null) &&
@@ -331,7 +338,7 @@ test_expect_success 'auto-bitmaps do not complain if unavailable' '
 	test_must_be_empty actual
 '

