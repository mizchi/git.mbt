 	git -C bare.git -c repack.writebitmaps=false repack -a -d --filter=blob:none &&
@@ -464,7 +471,7 @@ test_expect_success '--filter works with --pack-kept-objects and .keep packs' '
 	)
 '
 
-test_expect_success '--filter-to stores filtered out objects' '
+test_expect_success !BIT_PACK_OBJECTS '--filter-to stores filtered out objects' '
